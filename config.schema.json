{
  "pluginAlias": "MqttSecuritySystemPlatform",
  "pluginType": "platform",
  "singular": true,
  "headerDisplay": "MQTT Security System Alarm Configuration",
  "footerDisplay": "Configure MQTT connection and sensor behavior.",
  "schema": {
    "type": "object",
    "properties": {

      "alarmName": {
        "title": "Alarm Accessory Name",
        "type": "string",
        "default": "Home Alarm"
      },

      "mqttHost": {
        "title": "MQTT Host",
        "type": "string",
        "placeholder": "192.168.1.10"
      },

      "mqttPort": {
        "title": "MQTT Port",
        "type": "number",
        "default": 1883
      },

      "mqttUsername": {
        "title": "MQTT Username",
        "type": "string"
      },

      "mqttPassword": {
        "title": "MQTT Password",
        "type": "string"
      },

      "exitDelay": {
        "title": "Exit Delay (seconds, 0 disables)",
        "type": "number",
        "default": 0,
        "minimum": 0
      },

      "alarmDuration": {
        "title": "Alarm Duration (seconds)",
        "type": "number",
        "default": 120,
        "minimum": 10
      },

      "devices": {
        "title": "Sensors",
        "type": "array",
        "items": {
          "type": "object",
          "title": "Sensor",
          "properties": {

            "name": {
              "type": "string",
              "title": "Device Name",
              "placeholder": "Front Door"
            },

            "topic": {
              "type": "string",
              "title": "MQTT Topic",
              "placeholder": "sensors/front_door",
              "decription": "MQTT state topic for alarm sensors"
            },

            "payloadOn": {
              "type": "string",
              "title": "Payload On",
              "placeholder": "on",
              "description": "MQTT payload on for the sensor."
            },

            "payloadOff": {
              "type": "string",
              "title": "Payload Off",
              "placeholder": "off",
              "description": "MQTT payload off for the sensor."
            },
            "type": {
              "type": "string",
              "title": "Sensor Type",
              "enum": ["contact", "motion"],
              "default": "contact"
            },

            "armHome": {
              "type": "boolean",
              "title": "Armed in Home Mode",
              "default": false
            },

            "armAway": {
              "type": "boolean",
              "title": "Armed in Away Mode",
              "default": true
            },
            
            "armNight": {
              "type": "boolean",
              "title": "Armed in Night Mode",
              "default": false
            },

            "doubleKnock": {
              "type": "boolean",
              "title": "Double Knock",
              "default": false,
              "description": "Requires 2 or more of the double knock sensors to trip the alarm."
            },
            
            "entryDelay": {
              "type": "number",
              "title": "Entry Delay (seconds)",
              "default": 0,
              "minimum": 0,
              "description": "Delay before alarm triggers when this sensor is activated."
            }

          },
          "required": ["name", "topic", "payloadOn", "payloadOff", "type"]
        }
      }

    },
    "required": ["mqttHost"]
  }
}
